[Unit]
Description=Kader⁴² Tablet Switcher (%I)
DefaultDependencies=no
Conflicts=shutdown.target
Before=shutdown.target

[Service]
Type=exec
ExecStart=/usr/bin/plasma-convertible-switcher.sh %I
TimeoutStopSec=5
# Wir nehmen die aggressiven IO-Settings raus und nutzen nur Nice
Nice=-10

[Install]
WantedBy=multi-user.target