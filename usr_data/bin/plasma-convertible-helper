#!/bin/bash
if [ "$1" == "--enable-linger" ]; then
    # Suche den ersten User mit UID >= 1000
    TARGET_USER=$(getent passwd | awk -F: '$3>=1000 && $3<60000 {print $1}' | head -n1)
    if [ -n "$TARGET_USER" ]; then
        loginctl enable-linger "$TARGET_USER"
        touch /var/lib/plasma-convertible-linger.done
    fi
fi