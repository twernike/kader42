#!/usr/bin/env python3

import time
import subprocess

MODE = None

def run(cmd):
    return subprocess.run(cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def get_keyboard_present():
    # simple heuristic: any keyboard device present
    try:
        out = subprocess.check_output("ls /dev/input/by-id/", shell=True).decode()
        return "kbd" in out.lower()
    except:
        return True

def get_orientation():
    # fallback: assume landscape (you can extend later with iio)
    return "landscape"

def compute_mode():
    keyboard = get_keyboard_present()
    orientation = get_orientation()

    tablet_score = 0
    laptop_score = 0

    if not keyboard:
        tablet_score += 2
    else:
        laptop_score += 2

    if orientation == "portrait":
        tablet_score += 2

    return "tablet" if tablet_score > laptop_score else "laptop"

def apply_mode(mode):
    global MODE
    if mode == MODE:
        return

    print(f"Switching mode → {mode}")

    if mode == "tablet":
        # Plasma Dashboard (Kickoff Alternative)
        run("qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "
            "'panels().forEach(p => p.hiding = \"autohide\");'")

        # unlock rotation (KWin safe call via KScreen is version dependent)
        run("qdbus org.kde.KWin /KWin org.kde.KWin.setScreenOrientationLock false")

    else:
        # classic mode
        run("qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "
            "'panels().forEach(p => p.hiding = \"none\");'")

        # lock rotation
        run("qdbus org.kde.KWin /KWin org.kde.KWin.setScreenOrientationLock true")

    MODE = mode

def main():
    global MODE

    print("Kader Mode Daemon started")

    while True:
        mode = compute_mode()
        apply_mode(mode)
        time.sleep(2)

if __name__ == "__main__":
    main()