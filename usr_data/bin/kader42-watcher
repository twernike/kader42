#!/bin/bash
# =================================================================
# Kader42 Tablet-Watcher: Final Plasma 6 Edition
# =================================================================

BUS_DEST="org.kde.KWin"
BUS_PATH="/org/kde/KWin"
BUS_IFACE="org.kde.KWin.TabletModeManager"
echo "Kader42-Watcher started..."
sleep 2  # A brief delay to ensure that the session has fully started

# 1. INITIAL CHECK AT STARTUP
# (To ensure the panel is correct immediately after booting/logging in)
echo "[Kader42-Watcher] Initial check to determine whether tablet mode or desktop mode is active after login..."
IS_TABLET=$(qdbus6 $BUS_DEST $BUS_PATH $BUS_IFACE.tabletMode)

if [ "$IS_TABLET" = "true" ]; then
    echo "[Kader42-Watcher] Tablet mode is initially enabled"
    /usr/bin/plasma-convertible-switcher 1
else
    echo "[Kader42-Watcher] Desktop-Mode is initially enabled"
    /usr/bin/plasma-convertible-switcher 0
fi

# 2. EVENT LOOP (Waits for hardware signals)
echo "[Kader42-Watcher] Watcher active - Waiting for hardware events..."

dbus-monitor --session "type='signal',path='$BUS_PATH',interface='$BUS_IFACE',member='tabletModeChanged'" | \
while read -r line; do
    # We retrieve the current value of the property for every signal
    CURRENT_STATE=$(qdbus6 $BUS_DEST $BUS_PATH $BUS_IFACE.tabletMode)
    
    if [ "$CURRENT_STATE" = "true" ]; then
        echo "[Kader42-Watcher] Event: Tablet mode enabled"
        /usr/bin/plasma-convertible-switcher 1
    else
        echo "[Kader42-Watcher] Event: Desktop-Mode enabled"
        /usr/bin/plasma-convertible-switcher 0
    fi
done