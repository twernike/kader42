#!/usr/bin/env python3

import json
import os
import subprocess
import sys
import time
from pathlib import Path

# ------------------------------------------------------------
# CONFIG
# ------------------------------------------------------------

CONFIG_FILE = Path.home() / ".config" / "kwinoutputconfig.json"

TARGET_VALUE = "always"

WAIT_TIMEOUT = 30
WAIT_INTERVAL = 1


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------

def log(message):
    print(f"[kader42-autorotation-fix] {message}")


# ------------------------------------------------------------
# WAIT FOR CONFIG
# ------------------------------------------------------------

def wait_for_config():
    log("Waiting for KWin config...")

    for _ in range(WAIT_TIMEOUT):

        if CONFIG_FILE.exists():
            log(f"Found config: {CONFIG_FILE}")
            return True

        time.sleep(WAIT_INTERVAL)

    return False


# ------------------------------------------------------------
# LOAD JSON
# ------------------------------------------------------------

def load_config():
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as file:
            return json.load(file)

    except Exception as e:
        log(f"Failed to load JSON: {e}")
        sys.exit(1)


# ------------------------------------------------------------
# PATCH autoRotation
# ------------------------------------------------------------

def patch_autorotation(data):

    changed = False

    # --------------------------------------------------------
    # Root is an ARRAY
    # --------------------------------------------------------

    for block in data:

        # ----------------------------------------------------
        # We only want the "outputs" section
        # ----------------------------------------------------

        if block.get("name") != "outputs":
            continue

        outputs = block.get("data", [])

        # ----------------------------------------------------
        # Patch every output
        # ----------------------------------------------------

        for output in outputs:

            current = output.get("autoRotation")

            # Skip entries without autoRotation
            if current is None:
                continue

            # Already correct
            if current == TARGET_VALUE:
                continue

            connector = output.get("connectorName", "unknown")

            log(
                f"Patching {connector}: "
                f"{current} -> {TARGET_VALUE}"
            )

            output["autoRotation"] = TARGET_VALUE
            changed = True

    return changed


# ------------------------------------------------------------
# SAVE JSON
# ------------------------------------------------------------

def save_config(data):

    try:
        with open(CONFIG_FILE, "w", encoding="utf-8") as file:

            json.dump(
                data,
                file,
                indent=4
            )

        log("Config saved")

    except Exception as e:
        log(f"Failed to save JSON: {e}")
        sys.exit(1)


# ------------------------------------------------------------
# RECONFIGURE KWIN
# ------------------------------------------------------------

def reconfigure_kwin():

    log("Reconfiguring KWin...")

    try:
        subprocess.run(
            [
                "qdbus6",
                "org.kde.KWin",
                "/KWin",
                "reconfigure"
            ],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )

        log("KWin reconfigure signal sent")

    except Exception as e:
        log(f"Failed to reconfigure KWin: {e}")


# ------------------------------------------------------------
# MAIN
# ------------------------------------------------------------

def main():

    # --------------------------------------------------------
    # Wait for config file
    # --------------------------------------------------------

    if not wait_for_config():
        log("KWin config not found")
        sys.exit(0)

    # --------------------------------------------------------
    # Load JSON
    # --------------------------------------------------------

    data = load_config()

    # --------------------------------------------------------
    # Patch config
    # --------------------------------------------------------

    changed = patch_autorotation(data)

    if not changed:
        log("Nothing to patch")
    else:
        save_config(data)

    # --------------------------------------------------------
    # Tell KWin to reload
    # --------------------------------------------------------

    reconfigure_kwin()

    log("Done")


# ------------------------------------------------------------
# ENTRYPOINT
# ------------------------------------------------------------

if __name__ == "__main__":

    try:
        main()

    except KeyboardInterrupt:
        log("Interrupted")
        sys.exit(0)

    except Exception as e:
        log(f"Fatal error: {e}")
        sys.exit(1)