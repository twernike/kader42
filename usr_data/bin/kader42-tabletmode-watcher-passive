#!/bin/bash
# =================================================================
# Kader42 Silent Watcher - Zero-Interference Edition
# =================================================================

echo "[kader42-tabletmode-watcher] starting kader42-tabletmode-watcher..."

# 1. INITIAL CHECK (Via Kernel/IIO, not via KWin!)
# We query the sensor proxy directly to avoid KWin D-Bus requests.
if monitor-sensor --get | grep -q "tablet-mode: in-tablet-mode"; then
    echo "[kader42-tabletmode-watcher] Initial: Tablet detected"
    /usr/bin/plasma-convertible-switcher 1
else
    echo "[kader42-tabletmode-watcher] Initial: Desktop detected"
    /usr/bin/plasma-convertible-switcher 0
fi

# 2. PASSIVE MONITORING
# We only subscribe to the signal stream. 
dbus-monitor --session "type='signal',member='tabletModeChanged'" | \
while read -r line; do
    # We only parse what actually goes over the wire.
    if echo "$line" | grep -q "boolean true"; then
        echo "[kader42-tabletmode-watcher] Signal: -> TABLET"
        /usr/bin/plasma-convertible-switcher 1
    elif echo "$line" | grep -q "boolean false"; then
        echo "[kader42-tabletmode-watcher] Signal: -> DESKTOP"
        /usr/bin/plasma-convertible-switcher 0
    fi
done