import subprocess
import time
import os

# Konfiguration
THRESHOLD_SECONDS = 1.5  # Wie lange muss die Position stabil sein?
CHECK_INTERVAL = 0.5     # Abfrage-Intervall
BLACK_LIST_DEVICES = ["Mouse", "Logitech", "USB Optical Mouse"] # Maus-Erkennung

def is_mouse_connected():
    """Prüft, ob eine externe Maus angeschlossen ist."""
    try:
        devices = subprocess.check_output("lsusb", shell=True).decode()
        for d in BLACK_LIST_DEVICES:
            if d in devices:
                return True
    except:
        pass
    return False

def get_internal_output():
    """Findet den Namen des internen Displays."""
    try:
        out = subprocess.check_output("kscreen-doctor -o", shell=True).decode()
        for line in out.splitlines():
            if "connected" in line and "internal" in line.lower():
                return line.split()[0]
    except:
        return "eDP-1"
    return "eDP-1"

def rotate(orientation):
    output = get_internal_output()
    mapping = {
        "normal": "none",
        "bottom-up": "inverted",
        "left-up": "left",
        "right-up": "right"
    }
    rotation = mapping.get(orientation)
    if rotation:
        subprocess.run(f"kscreen-doctor output.{output}.rotation.{rotation}", shell=True)

def main():
    last_pos = ""
    candidate_pos = ""
    start_time = 0
    
    # Wir starten monitor-sensor als Subprozess
    proc = subprocess.Popen(["monitor-sensor"], stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    
    for line in iter(proc.stdout.readline, ""):
        if "Accelerometer orientation changed" in line:
            new_pos = line.split(": ")[-1].strip()
            
            if is_mouse_connected():
                continue # Rotation ignorieren, wenn Maus angeschlossen ist

            if new_pos != last_pos:
                if new_pos != candidate_pos:
                    candidate_pos = new_pos
                    start_time = time.time()
                else:
                    if (time.time() - start_time) >= THRESHOLD_SECONDS:
                        rotate(new_pos)
                        last_pos = new_pos

if __name__ == "__main__":
    main()