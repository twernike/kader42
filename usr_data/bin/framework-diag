#!/bin/bash
# framework-diag: Rundum-Check fÃ¼r Framework 12 (Hardware, HWDB, KDE-Software)

# Farben fÃ¼r die Optik
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

HWDB_FILE="/etc/udev/hwdb.d/61-framework.hwdb"
LIVE_USER=$(logname 2>/dev/null || echo $USER)
USER_HOME=$(getent passwd "$LIVE_USER" | cut -d: -f6)

echo -e "${YELLOW}=== Framework 12 Hardware & Config Check ===${NC}"

# 1. HWDB DATEI-CHECK (SYNTAX)
echo -n "[1/6] HWDB Syntax Check: "
if [ ! -f "$HWDB_FILE" ]; then
    echo -e "${RED}FEHLT${NC} ($HWDB_FILE)"
    ERR_HWDB=1
else
    if grep -q "^ACCEL_MOUNT_MATRIX" "$HWDB_FILE"; then
        echo -e "${RED}SYNTAX-FEHLER${NC} (Leerzeichen vor ACCEL fehlt!)"
        ERR_HWDB=1
    elif ! grep -q "sensor:modalias:acpi:FRMWC004" "$HWDB_FILE"; then
        echo -e "${RED}ID-FEHLER${NC} (Modalias FRMWC004 nicht gefunden)"
        ERR_HWDB=1
    else
        echo -e "${GREEN}OK${NC}"
    fi
fi

# 2. KERNEL & HARDWARE MATCH
echo -n "[2/6] Kernel Matrix-Load: "
MATRIX=$(udevadm info /sys/bus/iio/devices/iio:device0 2>/dev/null | grep "ACCEL_MOUNT_MATRIX")
if [[ -n "$MATRIX" ]]; then
    echo -e "${GREEN}GELADEN${NC}"
else
    echo -e "${RED}NICHT GELADEN${NC}"
    MODALIAS=$(cat /sys/bus/iio/devices/iio:device0/modalias 2>/dev/null)
    echo "      Kernel Modalias ist: $MODALIAS"
    ERR_KERNEL=1
fi

# 3. SENSOR-DIENST (IIO-PROXY)
echo -n "[3/6] iio-sensor-proxy: "
if systemctl is-active --quiet iio-sensor-proxy; then
    echo -e "${GREEN}LÃ„UFT${NC}"
else
    echo -e "${RED}INAKTIV${NC}"
    ERR_SERVICE=1
fi

# 4. KDE KONFIGURATION (BLOCKADEN)
echo "[4/6] Software-Blockaden:"
KSCREEN_DIR="$USER_HOME/.local/share/kscreen"
if [ -d "$KSCREEN_DIR" ] && [ "$(ls -A $KSCREEN_DIR 2>/dev/null)" ]; then
    echo -e "      - KScreen Cache: ${YELLOW}VORHANDEN${NC} (KÃ¶nnte stÃ¶ren)"
    WARN_KSCREEN=1
else
    echo -e "      - KScreen Cache: ${GREEN}SAUBER${NC}"
fi

# 5. DBUS INTERFACE (KWIN)
echo -n "[5/6] Plasma Auto-Rotation: "
AUTOROT=$(qdbus6 org.kde.KScreen /KScreen org.kde.kscreen.Rotation.autoRotation 2>/dev/null)
if [[ "$AUTOROT" == "true" ]]; then
    echo -e "${GREEN}AKTIV${NC}"
elif [[ "$AUTOROT" == "false" ]]; then
    echo -e "${RED}DEAKTIVIERT${NC}"
    ERR_PLASMA=1
else
    echo -e "${RED}UNBEKANNT${NC} (LÃ¤uft KDE?)"
fi

# 6. SENSOR LIVE-TEST
echo "[6/6] Sensor Live-Test (2 Sek. bewegen!):"
timeout --foreground 2s monitor-sensor | grep -E "Orientation|Accelerometer" || echo "      Warte auf Bewegung..."

echo "-------------------------------------------"
if [[ $ERR_HWDB || $ERR_KERNEL || $ERR_SERVICE ]]; then
    echo -e "${RED}STATUS: HARDWARE-EBENE DEFEKT${NC}"
elif [[ $ERR_PLASMA || $WARN_KSCREEN ]]; then
    echo -e "${YELLOW}STATUS: HARDWARE OK, SOFTWARE-BLOCKADE MÃ–GLICH${NC}"
else
    echo -e "${GREEN}STATUS: ALLES BEREIT - CONVERTIBLE SOLLTE LAUFEN${NC}"
fi
echo "==========================================="