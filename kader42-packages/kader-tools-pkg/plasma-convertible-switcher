#!/bin/bash
# /usr/bin/plasma-convertible-switcher

SYSTEM_LANG=$(echo ${LANG:-de} | cut -c1-2)
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"

switch_launcher(){
    local MODE=$1
    [[ "$MODE" != "0" && "$MODE" != "1" ]] && exit 1

    # Status-Check (Debounce)
    STATE_FILE="/tmp/plasma-convertible-state"
    [ -f "$STATE_FILE" ] && [ "$(cat "$STATE_FILE")" = "$MODE" ] && exit 0
    echo "$MODE" > "$STATE_FILE"

    # Ziel-Plugin festlegen
    if [ "$MODE" = "1" ]; then
        TARGET="org.kde.plasma.kickerdash"
    else
        TARGET="org.kde.plasma.kickoff"
    fi

    # Das JS-Script: Wir ändern nur den Typ, um die Position zu erhalten
    read -r -d '' JS <<EOF
    var allPanels = panels();
    for (var i = 0; i < allPanels.length; i++) {
        var widgets = allPanels[i].widgets();
        for (var j = 0; j < widgets.length; j++) {
            if (widgets[j].type === "org.kde.plasma.kickoff" || widgets[j].type === "org.kde.plasma.kickerdash") {
                // Nur ändern, wenn es nicht schon der Zieltyp ist
                if (widgets[j].type !== "$TARGET") {
                    widgets[j].type = "$TARGET";
                }
            }
        }
    }
EOF

    # Ausführen via DBus
    qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$JS"

    # Benachrichtigung
    local icon="computer"; local title="Kader⁴² Hybrid Switch"; local msg=""
    if [ "$MODE" == "1" ]; then
        icon="tablet"
        [ "$SYSTEM_LANG" == "de" ] && msg="Tablet-Modus aktiviert" || msg="Tablet mode activated"
    else
        icon="laptop"
        [ "$SYSTEM_LANG" == "de" ] && msg="Notebook-Modus aktiviert" || msg="Laptop mode activated"
    fi

    notify-send -u low -a "System" -i "$icon" "$title" "$msg"
}

switch_launcher $1