# Maintainer: Thomas Wernike <support@kader42.de>
pkgname=kader42-convertible-tools
pkgver=1.0.2
pkgrel=1
pkgdesc="An event listener and a launcher switcher that ensures you have the Dash menu in tablet mode and the standard Start menu in laptop mode."
arch=('any')
url="https://kader42.de"
license=('GPL')
depends=('bash' 'dbus' )
provides=('kader-tools')

source=('kader42-tablet-listener.service'
        'kader42-tablet-event-listener'
        'kader42-launcher-switcher'
        )
md5sums=('SKIP' 'SKIP' 'SKIP')

package() {
  # 1. Create the directories in the package image ($pkgdir)
  # -D creates any missing parent directories; -m755 sets execution permissions
  
  # Skripte nach /usr/bin kopieren
  install -Dm755 "${srcdir}/kader42-tablet-listener.service" "${pkgdir}/usr/bin/kader42-tablet-listener.service"
  install -Dm755 "${srcdir}/kader42-tablet-event-listener" "${pkgdir}/usr/bin/kader42-tablet-event-listener"
  install -Dm755 "${srcdir}/kader42-launcher-switcher" "${pkgdir}/usr/bin/kader42-launcher-switcher"
}