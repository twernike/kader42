# Maintainer: Thomas Wernike <support@kader42.de>
pkgname=kader-tools
pkgver=1.0.0
pkgrel=5
pkgdesc="An event listener and a launcher switcher that ensures you have the Dash menu in tablet mode and the standard Start menu in laptop mode."
arch=('any')
url="https://kader42.de"
license=('GPL')
depends=('bash' 'dbus' )

# Hier listen wir die Dateien auf, die im Ordner liegen
source=('kader42-event-listener.py'
        'plasma-convertible-switcher'
        )
md5sums=('SKIP' 'SKIP')

package() {
  # 1. Create the directories in the package image ($pkgdir)
  # -D creates any missing parent directories; -m755 sets execution permissions
  
  # Skripte nach /usr/bin kopieren
  install -Dm755 "${srcdir}/kader42-event-listener.py" "${pkgdir}/usr/bin/kader42-event-listener.py"
  install -Dm755 "${srcdir}/plasma-convertible-switcher" "${pkgdir}/usr/bin/plasma-convertible-switcher"
}