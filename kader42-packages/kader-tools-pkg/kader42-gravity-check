#!/bin/bash

# Sprache ermitteln (Default auf Englisch, falls leer)
SYSTEM_LANG=${LANG:0:2}

# Check, ob der Beschleunigungssensor fehlt
if ! monitor-sensor --get | grep -q 'Accelerometer'; then
    systemctl restart iio-sensor-proxy
    
    # Text festlegen
    case "$SYSTEM_LANG" in
        de) msg="Sensoren nach Dock-Trennung reaktiviert" ;;
        *)  msg="Sensors reactivated after dock disconnection" ;;
    esac

    # Benachrichtigung an den User senden (unter Wayland/Plasma)
    # Wir suchen den aktuell eingeloggten User, um das Icon auf dessen Screen zu werfen
    CURRENT_USER=$(who | awk '{print $1}' | head -n1)
    if [ -n "$CURRENT_USER" ]; then
        sudo -u "$CURRENT_USER" DISPLAY=:0 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u "$CURRENT_USER")/bus notify-send -i "dialog-information" "Kader⁴²" "$msg"
    fi
fi