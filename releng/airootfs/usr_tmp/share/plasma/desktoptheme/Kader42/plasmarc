[Appearance]
Description=Kader42 Default Theme
Name=Kader⁴²

[AdaptiveTransparency]
# Das sorgt dafür, dass das Panel nur transparent ist, wenn kein Fenster es berührt
enabled=true

[ContrastEffect]
# Erhöht die Lesbarkeit von weißem Text auf hellem Glas/Hintergrund
enabled=true
contrast=0.2
intensity=2.0
saturation=1.5

[BlurEffect]
# Aktiviert den Blur explizit für dieses Plasma-Theme
enabled=true

[Wallpapers]
# Hier gibst du den Ordnernamen deines Wallpaper-Pakets unter /usr/share/wallpapers/ an
defaultWallpaperTheme=Kader42