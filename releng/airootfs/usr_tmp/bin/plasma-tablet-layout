#!/bin/bash

MODE=$(qdbus org.kde.KWin /KWin org.kde.KWin.tabletMode)

if [ "$MODE" = "true" ]; then
    qdbus org.kde.plasmashell /PlasmaShell evaluateScript \
    "panels()[0].height = gridUnit * 4"
else
    qdbus org.kde.plasmashell /PlasmaShell evaluateScript \
    "panels()[0].height = gridUnit * 2.5"
fi