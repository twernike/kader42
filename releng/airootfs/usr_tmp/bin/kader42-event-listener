#!/bin/bash
# /usr/bin/kader42-event-listener

BUS="org.kde.KWin"
OBJ="/org/kde/KWin"
IFACE="org.kde.KWin.TabletModeManager"

echo "👀 Kader42 Event Listener started..."

# Ensure DBus
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"

# Wait for KWin
until qdbus6 $BUS $OBJ org.freedesktop.DBus.Introspectable.Introspect >/dev/null 2>&1; do
    sleep 1
done

echo "[kader42-event-listener] KWin ready"

# Reset to default settings (IMPORTANT!)
STATE=$(qdbus6 $BUS $OBJ $IFACE.tabletMode 2>/dev/null)

if [ "$STATE" = "true" ]; then
    /usr/bin/plasma-convertible-switcher 1
else
    /usr/bin/plasma-convertible-switcher 0
fi

echo "[kader42-event-listener] 👂🏻 Listening for tablet mode changes..."

# 🔥 Event Listener
gdbus monitor --session --dest org.kde.KWin |
while read -r line; do

    # Nur relevante Events
    if [[ "$line" == *"TabletModeManager"* && "$line" == *"tabletModeChanged"* ]]; then
        
        read -r nextline

        if [[ "$nextline" == *"true"* ]]; then
            echo "[kader42-event-listener] 📱 Tablet mode ON"
            /usr/bin/plasma-convertible-switcher 1

        elif [[ "$nextline" == *"false"* ]]; then
            echo "[kader42-event-listener] Tablet mode OFF ➡️ laptop mode is active 💻"
            /usr/bin/plasma-convertible-switcher 0
        fi
    fi

done