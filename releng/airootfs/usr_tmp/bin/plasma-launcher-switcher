#!/bin/bash
# /usr/local/bin/plasma-mode-monitor.sh

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
SYSTEM_LANG=$(echo $LANG | cut -c1-2)

switch_launcher() {
    local mode=$1
    local icon="computer"; local title="Plasma Hybrid"; local msg=""

    case "$SYSTEM_LANG" in
        de) [ "$mode" == "tablet" ] && msg="Tablet-Modus aktiviert" && icon="tablet" || msg="Notebook-Modus aktiviert" ;;
        *)  [ "$mode" == "tablet" ] && msg="Tablet mode activated" && icon="tablet" || msg="Laptop mode activated" ;;
    esac

    notify-send -a "System" -i "$icon" "$title" "$msg"

    # JS-Logik: Sucht Widgets nach Typ und setzt Alt+F1
    if [ "$mode" == "tablet" ]; then
        TARGET="org.kde.plasma.kickerdash"; OLD="org.kde.plasma.kickoff"
    else
        TARGET="org.kde.plasma.kickoff"; OLD="org.kde.plasma.kickerdash"
    fi

    JS="var allPanels = panels(); for (var i in allPanels) { var widgets = allPanels[i].widgets(); for (var j in widgets) { var w = widgets[j]; if (w.type === '$TARGET') { w.currentConfigGroup = ['Shortcuts']; w.writeConfig('globalShortcut', 'Alt+F1'); } else if (w.type === '$OLD') { w.currentConfigGroup = ['Shortcuts']; w.writeConfig('globalShortcut', ''); } } }"
    
    timeout 2s qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$JS"
}

# --- LOGIK-STEUERUNG ---

# Fall A: Manuelles Argument (tablet/desktop)
if [ "$1" == "tablet" ] || [ "$1" == "desktop" ]; then
    switch_launcher "$1"
    exit 0
fi

# Fall B: Automatischer Modus (Listener)
# Initialer Check beim Start
CHASSIS=$(cat /sys/class/dmi/id/chassis_type 2>/dev/null)
[[ "$CHASSIS" == "10" || "$CHASSIS" == "31" ]] && switch_launcher "tablet" || switch_launcher "desktop"

# Endlos-Listener
/usr/lib/libinput/libinput-debug-events 2>/dev/null | while read -r line; do
    if echo "$line" | grep -q "switch tablet-mode state 1"; then
        switch_launcher "tablet"
    elif echo "$line" | grep -q "switch tablet-mode state 0"; then
        switch_launcher "desktop"
    fi
done