<policyconfig>
 <action id="org.calamares.calamares">
 <message>Start Kader⁴² system installation with root access rights.</message>
 <icon_name>calamares</icon_name>
 <defaults>
 <allow_any>no</allow_any>
 <allow_inactive>no</allow_inactive>
 <allow_active>yes</allow_active>
 </defaults>
 <annotate key="org.freedesktop.policykit.exec.path">/usr/bin/calamares</annotate>
 <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
 </action>
</policyconfig>